{
  "name": "garden",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "lint": "oxlint --config .oxlintrc.json --ignore-pattern 'frontend/.svelte-kit/**' packages/ backend/ frontend/src/",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod-schema-faker": "^2.1.0"
  }
}
